# Persona MCP Configuration
# Copy to .env and customize for your setup

# Manifest directories (comma-separated list, processed in order)
# Later directories override earlier ones for same sections
MANIFEST_DIRS=./manifest

# Example for multiple manifest directories:
# MANIFEST_DIRS=./manifest_base,./manifest_custom

# Example for external directories:
# MANIFEST_DIRS=./manifest,X:/somepath/manifest_share

# Optional: shell command to launch an agent (used by scripts/launch-team.js)
# LAUNCH_CMD=claude
